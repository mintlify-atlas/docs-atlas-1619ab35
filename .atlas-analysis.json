  "keyFeatures": [
    "Real-time TCP audio streaming with sub-millisecond timing precision",
    "Smart silence detection with RMS-based bandwidth optimization",
    "Adaptive buffer sizing based on network jitter",
    "Multi-profile configuration management",
    "Cross-platform system audio capture (WASAPI, CoreAudio, ALSA)",
    "Auto-reconnect with exponential backoff",
    "System tray integration with background operation",
    "Real-time statistics and network quality monitoring",
    "QoS tagging (DSCP/TOS) support",
    "Token bucket pacing algorithm for drift-free transmission"
  ],
  "publicApiSurface": [
    "get_input_devices() - Lists available audio input devices",
    "start_stream() - Starts audio streaming with configuration",
    "stop_stream() - Stops active audio stream",
    "get_os_type() - Returns platform information",
    "Event: log-event - Real-time logging events",
    "Event: stats-event - Stream statistics (bitrate, uptime, bytes sent)",
    "Event: quality-event - Network quality metrics (jitter, latency, buffer health)",
    "Event: buffer-resize-event - Adaptive buffer size changes",
    "Configuration: Sample rates (44.1kHz, 48kHz)",
    "Configuration: Buffer sizes (256, 512, 1024, 2048 samples)",
    "Configuration: Ring buffer duration (2000-15000ms)",
    "Configuration: Network presets (Ethernet, WiFi, WiFi Poor)",
    "Configuration: DSCP strategies (VoIP, Low Delay, Throughput)"
  ]
}
